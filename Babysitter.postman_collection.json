{
  "info": {
    "name": "Babysitter API",
    "description": "אוסף בקשות לכל ה-routes של שרת ה-Babysitter (Node.js + Express). הגדירו משתנה סביבה baseUrl=http://localhost:3000 ו-token (מתקבל מ-Register/Login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register – family",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "הרשמת משתמש משפחה. מחזיר user + JWT token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"משפחת כהן\",\n  \"phone\": \"0501112222\",\n  \"email\": \"family@example.com\",\n  \"address\": \"רוטשילד 40, תל אביב\",\n  \"password\": \"0501112222\",\n  \"role\": \"family\",\n  \"children\": 2\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register – sitter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "הרשמת בייביסיטר. נוסף אוטומטית גם ל-sitters ומופיע בחיפוש.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"נועה לוי\",\n  \"phone\": \"0503334444\",\n  \"email\": \"sitter@example.com\",\n  \"address\": \"חיפה\",\n  \"password\": \"0503334444\",\n  \"role\": \"sitter\",\n  \"birthdate\": \"2002-05-10\",\n  \"experience\": \"4\",\n  \"area\": \"hfa\",\n  \"rate\": 75\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register – missing fields (400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "דוגמת שגיאה: שדות חובה חסרים.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"חסר\",\n  \"email\": \"x@x.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "התחברות. מחזיר user + token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"family@example.com\",\n  \"password\": \"0501112222\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login – wrong password (401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "דוגמת שגיאה: פרטים שגויים.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"family@example.com\",\n  \"password\": \"wrong\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get me (protected)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "פרטי המשתמש המחובר. דורש Authorization: Bearer token."
          },
          "response": []
        }
      ]
